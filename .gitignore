# ============================================================
# 操作系统
# ============================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*

# ============================================================
# 编辑器 & IDE
# ============================================================

# VS Code — pattern uses .vscode/* not .vscode/ so the ! unignore lines
# below actually take effect (git: 父目录被排除则文件无法 unignore)。
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetBrains (IntelliJ, WebStorm, PyCharm …)
.idea/
*.iml
*.iws
*.ipr
out/

# Vim / Neovim
*.swp
*.swo
*~
Session.vim
.netrwhist

# Emacs
\#*\#
.\#*
*.elc

# Sublime Text
*.sublime-project
*.sublime-workspace

# ============================================================
# 依赖 & 包管理
# ============================================================

# Node.js
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
**/.pnpm-store/
**/.npm/
**/.yarn/cache
**/.yarn/unplugged
**/.yarn/build-state.yml
**/.yarn/install-state.gz

# Python
**/__pycache__/
*.py[cod]
*$py.class
*.pyo
**/.venv/
**/venv/
**/env/
**/.env/
pip-log.txt
pip-delete-this-directory.txt
.Python

# Java / Kotlin / Gradle / Maven
*.class
*.jar
*.war
*.ear
*.nar
**/target/
**/build/
**/.gradle/
**/.mvn/

# Go
**/vendor/

# Rust
**/target/

# backend 编译产物——`go build ./cmd/<x>` 在 backend/ 留下与子命令同名的二进制
# （Makefile 全用 `go run` / `-o bin/`，这些散件从不被消费；曾误 commit）。
# 当前 cmd/ = server · docs。
backend/server
backend/docs
backend/cmd/server/server
backend/bin/
Cargo.lock       # 库项目取消注释此行；应用项目应保留

# Ruby
**/.bundle/
**/vendor/bundle
*.gem

# PHP / Composer
**/vendor/
composer.lock   # 如为库项目，取消注释此行

# ============================================================
# 构建产物
# ============================================================
bin/
**/dist/
**/build/
**/out/
**/.next/
**/.nuxt/
**/.svelte-kit/
**/.output/
*.min.js
*.min.css

