# ============================================================
# 文档生成
# ============================================================
**/docs/_build/
**/site/
**/.docusaurus/

# ============================================================
# Claude Code 本地状态
# ============================================================
# .claude/ 含 Claude Code 的本地状态（settings.local.json /
# scheduled_tasks.lock 等）。Per-machine 运行时数据，不进 git。
.claude/

# ============================================================
# mise 本地覆盖（用户机器特定，不入库）
# ============================================================
# mise.toml = 工具链钉版本（已跟踪，源）。mise.local.toml / .mise.local.toml = 个人本地覆盖,
# 不入库。装的工具在 ~/.local/share/mise（全局,非仓库)。
mise.local.toml
.mise.local.toml
.mise/

# ============================================================
# Pipeline 测试副产物
# ============================================================
# Playwright MCP server 在 cwd 写 trace/screenshot dir。
# Curated marketplace pipeline 测试默认 cwd 是 backend/test/mcp/。
.playwright-mcp/
# ============================================================
# Backend runtime sandbox data
# ============================================================
# Created when running 'go run ./cmd/server' from backend/ (default
# data-dir resolves under cwd). Contains the lazily-downloaded runtimes
# (python/node/uv/dotnet) — large (~100MB+), regenerable, never commit.
backend/sandbox/

# ============================================================
# 泄漏战役量测实验室（.leak-lab）
# ============================================================
# 量尺脚本 + 快照产物（机器指纹/进程表/diff）。纯本机量测数据，不入库。
.leak-lab/
