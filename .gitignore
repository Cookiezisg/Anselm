# ============================================================
*.log
**/logs/
**/tmp/
**/temp/
*.tmp
*.bak
*.orig
*.rej

# ============================================================
# 测试 & 覆盖率
# ============================================================
**/coverage/
.coverage
*.lcov
**/.nyc_output/
**/htmlcov/
**/.pytest_cache/
**/.tox/

# ============================================================
# 数据库
# ============================================================
*.sqlite
*.sqlite3
*.db
*.mdb

